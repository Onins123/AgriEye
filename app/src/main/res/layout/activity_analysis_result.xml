<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- FULL SCREEN LEAF IMAGE -->
    <ImageView
        android:id="@+id/imageView_ResultOfAnalysis"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        tools:srcCompat="@tools:sample/avatars" />

    <!-- BACK BUTTON — floats over the image -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="40dp"
        android:background="@drawable/circle_button_bg"
        android:contentDescription="Back"
        android:src="@drawable/ic_back" />

    <!-- BOTTOM SHEET -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/bottomSheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_peekHeight="250dp"
        app:behavior_hideable="false">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- DRAG HANDLE + HEADER -->
            <LinearLayout
                android:id="@+id/sheetHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:background="@drawable/bottom_sheet_bg"
                android:paddingTop="10dp"
                android:paddingBottom="16dp"
                app:layout_constraintTop_toTopOf="parent">

                <!-- Drag handle pill -->
                <View
                    android:layout_width="40dp"
                    android:layout_height="4dp"
                    android:background="#BBBBBB"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Result"
                    android:textColor="#4c5522"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-black" />

                <TextView
                    android:id="@+id/tvSwipeHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Swipe up to see analysis"
                    android:textColor="#7a8662"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- ALL CARDS -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/sheetContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#ecf1dc"
                android:paddingBottom="32dp"
                android:minHeight="1000dp"
                app:layout_constraintTop_toBottomOf="@+id/sheetHeader">

                <!-- DIAGNOSIS CARD -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardDiagnosis"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="#ecf1dc"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <ImageView
                            android:id="@+id/iconDiag"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_diagnosis" />

                        <TextView
                            android:id="@+id/labelDiag"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="DIAGNOSIS"
                            android:textColor="#4c5522"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="@+id/iconDiag"
                            app:layout_constraintStart_toEndOf="@+id/iconDiag"
                            app:layout_constraintTop_toTopOf="@+id/iconDiag" />

                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            app:cardBackgroundColor="#e2e8cf"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:layout_constraintTop_toBottomOf="@+id/labelDiag">

                            <androidx.constraintlayout.widget.ConstraintLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:padding="12dp">

                                <TextView
                                    android:id="@+id/tv_diseaseType_value"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Leaf Blast"
                                    android:textColor="#3D4D21"
                                    android:textSize="22sp"
                                    android:textStyle="bold"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toTopOf="parent" />

                                <TextView
                                    android:id="@+id/tv_severityLevel_value"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:layout_marginEnd="8dp"
                                    android:text="Severity Level: 15% (Moderate)"
                                    android:textColor="#3D4D21"
                                    app:layout_constraintEnd_toStartOf="@+id/tv_severityClassification_value"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toBottomOf="@+id/tv_diseaseType_value" />

                                <TextView
                                    android:id="@+id/tv_severityClassification_value"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="SES 5"
                                    android:textColor="#3D4D21"
                                    android:textStyle="bold"
                                    app:layout_constraintBottom_toBottomOf="parent"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintTop_toTopOf="parent" />

                            </androidx.constraintlayout.widget.ConstraintLayout>
                        </androidx.cardview.widget.CardView>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>

                <!-- ABOUT THE DISEASE CARD -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardAbout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="#ecf1dc"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/cardDiagnosis">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <ImageView
                            android:id="@+id/iconAbout"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_diagnosis" />

                        <TextView
                            android:id="@+id/labelAbout"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:justificationMode="inter_word"
                            android:textAlignment="textStart"
                            android:text="ABOUT THE DISEASE"
                            android:textColor="#4c5522"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="@+id/iconAbout"
                            app:layout_constraintStart_toEndOf="@+id/iconAbout"
                            app:layout_constraintTop_toTopOf="@+id/iconAbout" />

                        <ImageView
                            android:id="@+id/iconChevronAbout"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_diagnosis"
                            app:layout_constraintBottom_toBottomOf="@+id/iconAbout"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/iconAbout" />

                        <androidx.cardview.widget.CardView
                            android:id="@+id/expandableAbout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:visibility="visible"
                            app:cardBackgroundColor="#e2e8cf"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:layout_constraintTop_toBottomOf="@+id/labelAbout">

                            <TextView
                                android:id="@+id/tv_commonCause_value"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:padding="12dp"
                                android:text="Fungus Name"
                                android:textColor="#3D4D21"
                                android:textSize="14sp" />
                        </androidx.cardview.widget.CardView>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>

                <!-- SYMPTOMS CARD -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardSymptoms"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="#ecf1dc"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/cardAbout">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <ImageView
                            android:id="@+id/iconSymptoms"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_diagnosis" />

                        <TextView
                            android:id="@+id/labelSymptoms"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="SYMPTOMS"
                            android:textColor="#4c5522"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="@+id/iconSymptoms"
                            app:layout_constraintStart_toEndOf="@+id/iconSymptoms"
                            app:layout_constraintTop_toTopOf="@+id/iconSymptoms" />

                        <ImageView
                            android:id="@+id/iconChevronSymptoms"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_diagnosis"
                            app:layout_constraintBottom_toBottomOf="@+id/iconSymptoms"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/iconSymptoms" />

                        <androidx.cardview.widget.CardView
                            android:id="@+id/expandableSymptoms"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:visibility="visible"
                            app:cardBackgroundColor="#e2e8cf"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:layout_constraintTop_toBottomOf="@+id/labelSymptoms">

                            <TextView
                                android:id="@+id/tv_symptoms_value"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:lineSpacingExtra="4dp"
                                android:padding="12dp"
                                android:justificationMode="inter_word"
                                android:textAlignment="textStart"
                                android:text="Symptoms appear here"
                                android:textColor="#3D4D21"
                                android:textSize="14sp" />
                        </androidx.cardview.widget.CardView>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>

                <!-- MANAGEMENT CARD -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardManagement"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="#ecf1dc"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/cardSymptoms">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <ImageView
                            android:id="@+id/iconManage"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_diagnosis" />

                        <TextView
                            android:id="@+id/labelManage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="MANAGEMENT"
                            android:textColor="#4c5522"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="@+id/iconManage"
                            app:layout_constraintStart_toEndOf="@+id/iconManage"
                            app:layout_constraintTop_toTopOf="@+id/iconManage" />

                        <ImageView
                            android:id="@+id/iconChevronManage"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_diagnosis"
                            app:layout_constraintBottom_toBottomOf="@+id/iconManage"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/iconManage" />

                        <androidx.cardview.widget.CardView
                            android:id="@+id/expandableManagement"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:visibility="visible"
                            app:cardBackgroundColor="#e2e8cf"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:layout_constraintTop_toBottomOf="@+id/labelManage">

                            <TextView
                                android:id="@+id/tvManagementTipsValue"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:lineSpacingExtra="4dp"
                                android:padding="12dp"
                                android:justificationMode="inter_word"
                                android:textAlignment="textStart"
                                android:text="Tips will appear here"
                                android:textColor="#3D4D21"
                                android:textSize="14sp" />
                        </androidx.cardview.widget.CardView>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>

                <!-- HOME BUTTON -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnHome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="16dp"
                    android:text="Home"
                    app:backgroundTint="@color/agri_dark_green"
                    android:textColor="@color/white"
                    app:iconGravity="textStart"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/cardManagement" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>




</androidx.coordinatorlayout.widget.CoordinatorLayout>